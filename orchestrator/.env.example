# ─── Soroban / Stellar ────────────────────────────────────────────────────────
# RPC endpoint for the Soroban-capable Horizon node
# Local:    http://localhost:8000/soroban/rpc
# Testnet:  https://soroban-testnet.stellar.org
# Mainnet:  https://soroban-mainnet.stellar.org
SOROBAN_RPC_URL=http://localhost:8000/soroban/rpc

# Network passphrase — must match the network above
# Local:    Standalone Network ; February 2017
# Testnet:  Test SDF Network ; September 2015
# Mainnet:  Public Global Stellar Network ; September 2015
SOROBAN_NETWORK_PASSPHRASE=Standalone Network ; February 2017

# Deployed contract addresses (output by deploy-testnet.sh / deploy-mainnet.sh)
SETTLEMENT_ESCROW_CONTRACT_ID=
COMPLIANCE_GATE_CONTRACT_ID=

# Stellar secret key used by the orchestrator to submit transactions
# Generate with: stellar keys generate orchestrator-key && stellar keys show orchestrator-key
# WARNING: never commit a real secret key; use a secrets manager in production
ORCHESTRATOR_SECRET_KEY=

# ─── Database (PostgreSQL) ────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=atomic_settle
DB_PASSWORD=atomic_settle
DB_DATABASE=atomic_settle
# Set to false in production — use explicit migrations instead
DB_SYNC=true

# ─── Event listener ──────────────────────────────────────────────────────────
# Set to true to enable the Soroban event polling loop
EVENT_LISTENER_ENABLED=false
# How often to poll for new contract events (milliseconds)
EVENT_POLL_INTERVAL_MS=5000

# ─── HTTP server ─────────────────────────────────────────────────────────────
PORT=3000

# ─── Compliance provider (optional — leave blank to use on-chain gate only) ──
# KYC_PROVIDER_URL=https://your-kyc-provider.example.com
# KYC_PROVIDER_API_KEY=
